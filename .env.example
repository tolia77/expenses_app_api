PORT=3004

DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postpass
DATABASE_NAME=expenses_app

JWT_SECRET=local-dev-secret-change-in-prod
JWT_EXPIRES_IN=7d

STORAGE_ENDPOINT=http://garage:3900
STORAGE_PUBLIC_ENDPOINT=http://localhost:3900
STORAGE_BUCKET=receipts-bucket
STORAGE_ACCESS_KEY=dev-access-key
STORAGE_SECRET=dev-secret-change-in-prod
STORAGE_REGION=garage
STORAGE_PRESIGN_TTL=300

# v2.0 — AI receipt parsing
OPENROUTER_API_KEY=sk-or-v1-REPLACE-ME
# Comma-separated model tier chain, cheapest first. BullMQ attempts = chain length;
# each retry escalates to the next tier. AI_MODEL (single model) is still honored
# as a chain-of-one if AI_MODEL_CHAIN is unset.
AI_MODEL_CHAIN=google/gemini-3.1-flash-lite-preview,google/gemini-3-flash-preview,google/gemini-3-flash
AI_BASE_URL=https://openrouter.ai/api/v1

# v2.0 — Redis (BullMQ queue)
REDIS_HOST=redis
REDIS_PORT=6379
