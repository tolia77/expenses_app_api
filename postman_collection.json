{
  "info": {
    "name": "Expenses App API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "NestJS Expenses Tracker API — all routes"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3004"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "receiptId",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": ""
    },
    {
      "key": "merchantId",
      "value": ""
    },
    {
      "key": "expenseId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('token', res.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "  pm.collectionVariables.set('token', res.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('categoryId', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Groceries\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            }
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "{{categoryId}}"]
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Food & Dining\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "{{categoryId}}"]
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "{{categoryId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Merchants",
      "item": [
        {
          "name": "Create Merchant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('merchantId', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Walmart\",\n  \"address\": \"123 Main St\",\n  \"other_details\": { \"type\": \"retail\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/merchants",
              "host": ["{{baseUrl}}"],
              "path": ["merchants"]
            }
          }
        },
        {
          "name": "Get All Merchants",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/merchants",
              "host": ["{{baseUrl}}"],
              "path": ["merchants"]
            }
          }
        },
        {
          "name": "Get Merchant by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/merchants/{{merchantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["merchants", "{{merchantId}}"]
            }
          }
        },
        {
          "name": "Update Merchant",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Walmart Supercenter\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/merchants/{{merchantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["merchants", "{{merchantId}}"]
            }
          }
        },
        {
          "name": "Delete Merchant",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/merchants/{{merchantId}}",
              "host": ["{{baseUrl}}"],
              "path": ["merchants", "{{merchantId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Receipts",
      "item": [
        {
          "name": "Create Receipt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('receiptId', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant_id\": \"{{merchantId}}\",\n  \"payment_method\": \"credit_card\",\n  \"purchased_at\": \"2026-04-15T12:00:00Z\",\n  \"other_details\": { \"store_number\": \"42\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/receipts",
              "host": ["{{baseUrl}}"],
              "path": ["receipts"]
            }
          }
        },
        {
          "name": "Get All Receipts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/receipts",
              "host": ["{{baseUrl}}"],
              "path": ["receipts"]
            }
          }
        },
        {
          "name": "Get All Receipts (with date filter)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/receipts?from=2026-01-01&to=2026-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["receipts"],
              "query": [
                { "key": "from", "value": "2026-01-01" },
                { "key": "to", "value": "2026-12-31" }
              ]
            }
          }
        },
        {
          "name": "Get Receipt by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/receipts/{{receiptId}}",
              "host": ["{{baseUrl}}"],
              "path": ["receipts", "{{receiptId}}"]
            }
          }
        },
        {
          "name": "Update Receipt",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"cash\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/receipts/{{receiptId}}",
              "host": ["{{baseUrl}}"],
              "path": ["receipts", "{{receiptId}}"]
            }
          }
        },
        {
          "name": "Delete Receipt",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/receipts/{{receiptId}}",
              "host": ["{{baseUrl}}"],
              "path": ["receipts", "{{receiptId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Create Expense",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('expenseId', res.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": \"{{categoryId}}\",\n  \"name\": \"Milk\",\n  \"price\": 3.99,\n  \"unit_type\": \"gallon\",\n  \"amount\": 1,\n  \"other_details\": { \"brand\": \"Organic Valley\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/receipts/{{receiptId}}/expenses",
              "host": ["{{baseUrl}}"],
              "path": ["receipts", "{{receiptId}}", "expenses"]
            }
          }
        },
        {
          "name": "Get Expense by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/expenses/{{expenseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["expenses", "{{expenseId}}"]
            }
          }
        },
        {
          "name": "Update Expense",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Whole Milk\",\n  \"price\": 4.49\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/expenses/{{expenseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["expenses", "{{expenseId}}"]
            }
          }
        },
        {
          "name": "Delete Expense",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/expenses/{{expenseId}}",
              "host": ["{{baseUrl}}"],
              "path": ["expenses", "{{expenseId}}"]
            }
          }
        }
      ]
    }
  ]
}
